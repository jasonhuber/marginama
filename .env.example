APP_ENV=development
APP_URL=http://localhost:8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=marginama
DB_USER=root
DB_PASS=dev

# 32+ random chars. Generate with: php -r "echo bin2hex(random_bytes(32));"
SESSION_SECRET=replace-me-with-a-long-random-string

# User with this email sees /admin/suggestions. Leave blank to disable.
ADMIN_EMAIL=
# Where to send alert emails when users submit /feedback.
# Leave blank to log to the database only (no email fires).
SUGGESTIONS_ALERT_EMAIL=
# From address for system emails. Must be on the domain or SPF will fail.
FROM_EMAIL=noreply@marginama.com

# OpenAI key for semantic search over reviews/critiques.
# Leave blank to disable semantic search (tag filtering + text search still work).
OPENAI_API_KEY=

# ── Deploy creds (SSH) ───────────────────────────────────────────────────────
# Not read by the app at runtime; used by deploy tooling / the agent to ssh in,
# git pull, and apply schema on production. Leave blank for local dev.
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_PORT=65002
DEPLOY_SSH_PASSWORD=
DEPLOY_PATH=~/domains/marginama.com
